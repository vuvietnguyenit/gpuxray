{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Experimental: Memleak Trace cmd: trace all process",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "preLaunchTask": "make: build",
            "args": [
                "-i", "1",
                "-v", "debug",
                "memtrace",
            ]
        },
        {
            "name": "Experimental: Memleak Trace cmd: trace specific process",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "preLaunchTask": "make: build",
            "args": [
                "memtrace",
                "--pid", "2806854"
            ]
        },
        {
            "name": "Experimental: Memleak Trace cmd: stacktrace PID",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "preLaunchTask": "make: build",
            "args": [
                "memtrace",
                "--pid", "2289395",
                "--print-stacks"
            ]
        },
        {
            "name": "Run mon flag",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "preLaunchTask": "make: build",
            "args": [
                "mon",
                "--log-level", "debug",
            ]
        }
    ]
}